          {
            "name": "birdId",
            "in": "path",
            "required": true,
            "description": "The ID of the Bird whose logs are being retrieved.",
            "style": "simple",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "page",
            "in": "query",
            "description": "The zero-based page index to return.",
            "style": "form",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "pageSize",
            "in": "query",
            "description": "The number of log items to return per page.",
            "style": "form",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "ascending",
            "in": "query",
            "description": "Whether to sort the logs in ascending order by creation time.",
            "style": "form",
            "schema": {
              "type": "boolean"
            }
          },
          {
            "name": "from",
            "in": "query",
            "description": "Optional start timestamp to filter logs from, in ISO 8601 format, for example 2027-10-13T16:33:46Z.",
