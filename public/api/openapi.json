    "/nests/{nestId}/birds/{birdId}/flights": {
      "get": {
        "summary": "Search Flights",
        "description": "Search for Flights of the specified Nest. This endpoint is especially useful for applications that need to inspect Flight error messages to understand failed or cancelled Flights.",
        "operationId": "searchFlights",
        "tags": ["Flights"],
        "parameters": [
          {
            "name": "nestId",
            "in": "path",
            "required": true,
            "description": "The ID of the Nest that contains the Bird.",
            "style": "simple",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "birdId",
            "in": "path",
            "required": true,
            "description": "The ID of the Bird whose Flights are being listed.",
            "style": "simple",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "MinStartDate",
            "in": "query",
            "description": "Filters Flights to those with a start date on or after this timestamp.",
            "style": "form",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "MaxStartDate",
            "in": "query",
            "description": "Filters Flights to those with a start date on or before this timestamp.",
            "style": "form",
            "schema": {
              "type": "string",
              "format": "date-time"
            }
          },
          {
            "name": "Status",
            "in": "query",
            "description": "Filters Flights by status. Active Flights are currently running. Cancelled Flights were cancelled by a user.",
            "style": "form",
            "schema": {
              "type": "string",
              "enum": ["succeeded", "failed", "cancelled", "active"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A list of Flights for the specified Bird, including error messages when available.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/FlightEntity"
                  }
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "500": {
            "description": "Server Error"
          }
        }
      }
    },
