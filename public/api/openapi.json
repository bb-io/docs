{
  "openapi": "3.0.1",
  "info": {
    "title": "Blackbird.io API",
    "description": "This API provides generic app functions for the Blackbird.io system.",
    "version": "v1"
  },
  "servers": [
    {
      "url": "https://eu-1.blackbird.io/api-rest/",
      "description": "Blackbird EU-1 instance"
    },
    {
      "url": "https://us-2.blackbird.io/api-rest/",
      "description": "Blackbird US-2 instance"
    }
  ],
  "paths": {
    "/nests/{nestId}/birds": {
      "get": {
        "summary": "Search Birds in a Nest",
        "description": "Returns the Birds in a Nest. Results can be filtered by trigger type and status.",
        "operationId": "searchBirds",
        "tags": ["Birds"],
        "parameters": [
          {
            "name": "nestId",
            "in": "path",
            "required": true,
            "description": "The ID of the Nest that contains the Birds.",
            "style": "simple",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "TriggerType",
            "in": "query",
            "description": "Filters Birds by how they are triggered: manual, event, or scheduled. Only manual Birds can be triggered through the POST Bird endpoint in this API.",
            "style": "form",
            "schema": {
              "type": "string",
              "enum": ["manual", "event", "scheduled"]
            }
          },
          {
            "name": "Status",
            "in": "query",
            "description": "Filters Birds by status. Unpublished Birds are drafts. Active Birds are enabled. Suspended Birds were active Birds that were temporarily paused.",
            "style": "form",
            "schema": {
              "type": "string",
              "enum": ["active", "unpublished", "suspended"]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A list of Birds in the Nest.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/BirdEntity"
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "500": {
            "description": "Server Error"
          }
        }
      }
    },
    "/nests/{nestId}/birds/{birdId}": {
      "get": {
        "summary": "Get a Bird",
        "description": "Returns a single Bird in a Nest by its ID.",
        "operationId": "getBird",
        "tags": ["Birds"],
        "parameters": [
          {
            "name": "nestId",
            "in": "path",
            "required": true,
            "description": "The ID of the Nest that contains the Bird.",
            "style": "simple",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "birdId",
            "in": "path",
            "required": true,
            "description": "The ID of the Bird.",
            "style": "simple",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The requested Bird.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BirdEntity"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "500": {
            "description": "Server Error"
          }
        }
      },
      "post": {
        "summary": "Fly a Manual Bird",
        "description": "Starts a Flight for the specified Bird. Only Birds with a manual trigger type can be flown through this endpoint.",
        "operationId": "flyBird",
        "tags": ["Birds"],
        "parameters": [
          {
            "name": "nestId",
            "in": "path",
            "required": true,
            "description": "The ID of the Nest that contains the Bird.",
            "style": "simple",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "birdId",
            "in": "path",
            "required": true,
            "description": "The ID of the Bird. Only manual Birds can be triggered through this endpoint.",
            "style": "simple",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The Bird was successfully flown."
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "404": {
            "description": "Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "500": {
            "description": "Server Error"
          }
        }
      }
    },
    "/nests/{nestId}/birds/{birdId}/logs": {
      "get": {
        "summary": "Get Bird logs",
        "description": "Returns Bird related events such as publishing, saving and subscription errors.",
        "operationId": "getBirdLogs",
        "tags": ["Birds"],
        "parameters": [
          {
            "name": "nestId",
