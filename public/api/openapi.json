            "schema": {
              "type": "string"
            }
          },
          {
            "name": "birdId",
            "in": "path",
            "required": true,
            "description": "The ID of the Bird whose Flight is being retrieved.",
            "style": "simple",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "flightId",
            "in": "path",
            "required": true,
            "description": "The ID of the Flight.",
            "style": "simple",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The requested Flight.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FlightEntity"
